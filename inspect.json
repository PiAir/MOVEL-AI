            "file": "D:\\Temp\\MOVEL AI 2025-2026\\toets-jezelf.qmd",
            "source": "\nlibrary(\"exams2forms\")\n# List all question files starting with 'question-' in the 'quiz' folder\nquestion_pool <- list.files(path = \"quiz\", pattern = \"^question-.*\\\\.Rmd$\", full.names = TRUE)\n\nif (length(question_pool) > 0) {\n  # Randomly select up to 10 questions\n  n_select <- min(length(question_pool), 10)\n  set.seed(Sys.Date()) # Optional: same questions for everyone on the same day\n  selected_questions <- sample(question_pool, n_select)\n\n  # Render the selected questions\n  # exams2forms will produce multiple .webex-question divs\n  exams2forms::exams2forms(file = selected_questions, title = 'Randomized Quiz', browse = FALSE)\n} else {\n  cat(\"No questions found in the quiz/ directory.\")\n}\n",
            "language": "r",
            "metadata": {
              "echo": false,
              "results": "asis",
              "message": false,
              "warning": false
            }
          }
        ],
        "metadata": {
          "title": "Toets Jezelf!"
